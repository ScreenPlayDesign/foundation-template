# ── Dependencies ───────────────────────────────────────────────────────────────
node_modules/
.pnpm-store/

# ── Build output ───────────────────────────────────────────────────────────────
dist/
dist-ssr/

# ── Environment — NEVER commit secrets ────────────────────────────────────────
.env.local
.env.*.local
.env.production

# ── Playwright ────────────────────────────────────────────────────────────────
playwright-report/
test-results/
blob-report/
.playwright/

# ── Supabase local stack ──────────────────────────────────────────────────────
# supabase/config.toml   IS committed (project config, not a secret)
# supabase/migrations/   IS committed
# supabase/seed.sql      IS committed
# Everything else is runtime / generated by supabase CLI:
supabase/.branches/
supabase/.temp/

# ── Editor ────────────────────────────────────────────────────────────────────
.vscode/
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ── OS ────────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── Logs ──────────────────────────────────────────────────────────────────────
*.log
npm-debug.log*
bun-debug.log*

# ── TypeScript ────────────────────────────────────────────────────────────────
*.tsbuildinfo
