# ─────────────────────────────────────────────────────────────────────────────
# Dockerfile.dev — SPD project Vite dev server
#
# Part of the foundation-template. Every spd-project gets this file.
# Used exclusively for local development via docker-compose.yml.
# Production builds happen in CI (Cloudflare Pages) — not from this file.
#
# The source tree is bind-mounted at /app at runtime.
# node_modules lives inside the image to avoid host/container conflicts.
# ─────────────────────────────────────────────────────────────────────────────

FROM oven/bun:1-alpine AS dev

RUN apk add --no-cache git wget

WORKDIR /app

# Install deps as a cacheable layer — only re-runs when bun.lock changes.
COPY package.json bun.lock ./
RUN bun install --frozen-lockfile

EXPOSE 5173

# usePolling is set in vite.config.ts (server.watch.usePolling = true).
# Required for HMR to fire on macOS Docker Desktop (VirtioFS mounts).
CMD ["bun", "run", "dev", "--host"]
