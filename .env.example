# ── SPD project environment variables ────────────────────────────────────────
#
# Copy to .env.local and fill in values for each environment.
# NEVER commit .env.local — it is gitignored.
#
# ── Which database does the app connect to? ───────────────────────────────────
#
#   LOCAL (default, no .env.local needed):
#     VITE_SUPABASE_URL defaults to http://host.docker.internal:54321 in Docker,
#     or http://localhost:54321 on the host. Run `supabase start` first.
#
#   STAGING (for reviewing staging DB from local app):
#     Set VITE_SUPABASE_URL below to the cloud staging ref.
#     Used when staging DB needs to be inspected without going through the gate.
#     ⚠ Never write to staging from a local dev session — only read-inspect.
#
#   PROD:
#     Never used locally. CI (Cloudflare Pages) sets these automatically.

# ── Local Supabase (docker compose sets this; usually leave blank here) ────────
# VITE_SUPABASE_URL=http://localhost:54321
# VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6ImFub24iLCJleHAiOjE5ODM4MTI5OTZ9.CRFA0NiK7kyqd7B8LzSPCLMoW4raUmzqEsHV_oTxKpo

# ── Cloud staging (uncomment + fill to connect to the staging Supabase) ────────
# VITE_SUPABASE_URL=https://<staging-ref>.supabase.co
# VITE_SUPABASE_ANON_KEY=eyJ...

# ── Cloud prod (CI only — set as Cloudflare Pages env vars, not here) ──────────
# VITE_SUPABASE_URL=https://<prod-ref>.supabase.co
# VITE_SUPABASE_ANON_KEY=eyJ...

# ── App port (override if running multiple spd projects simultaneously) ─────────
# APP_PORT=5173

# ── OAuth providers ───────────────────────────────────────────────────────────
# These are read by the local Supabase CLI (supabase/config.toml uses env() refs).
# Only fill in the providers you've enabled in spd_config.toml [auth.providers]
# and set to `enabled = true` in supabase/config.toml.
#
# For all providers, the OAuth callback URL to register is:
#   Local:   http://localhost:54321/auth/v1/callback
#   Staging: https://<staging-ref>.supabase.co/auth/v1/callback
#   Prod:    https://<prod-ref>.supabase.co/auth/v1/callback
#
# Staging/prod credentials live in the Supabase cloud dashboard
# (Authentication → Providers), not here.
#
# VITE_AUTH_PROVIDERS controls which sign-in buttons the app renders.
# Default: google,github — every SPD app ships with both out of the box.
# Comma-separated list to add more: google,github,discord
# VITE_AUTH_PROVIDERS=google,github

# ── Google (console.cloud.google.com → APIs & Services → Credentials) ──────────
# Scopes needed: email, profile (included in default openid)
# GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=GOCSPX-your-client-secret

# ── GitHub (github.com → Settings → Developer settings → OAuth Apps) ───────────
# Scopes needed: read:user, user:email
# GITHUB_CLIENT_ID=your-client-id
# GITHUB_CLIENT_SECRET=your-client-secret

# ── Starter actor accounts (Albert, Beth, Carol) ────────────────────────────────
# Email + password is the default sign-in method for the three starter
# actors — zero external setup required. Run `bun run seed:actors` (needs
# SUPABASE_SERVICE_ROLE_KEY from `supabase status`, local dev only) to
# create these accounts, then set the values below to match — or just
# leave unset and use the defaults baked into scripts/seed-actors.ts.
# Same mechanism doubles as the OAuth test substitute once Google/GitHub
# are enabled for real (see screenplay/features/three-actors-sign-in.feature
# and screenplay/auto-spec/fixtures/auth.ts) — neither provider's real consent screen can
# be automated by Playwright. Getting these three scenarios passing is the
# actual signal that this project's identity foundations are laid.
# ALBERT_TEST_EMAIL=albert@example.com
# ALBERT_TEST_PASSWORD=
# BETH_TEST_EMAIL=beth@example.com
# BETH_TEST_PASSWORD=
# CAROL_TEST_EMAIL=carol@example.com
# CAROL_TEST_PASSWORD=

# SUPABASE_SERVICE_ROLE_KEY is required by scripts/seed-actors.ts only —
# never expose this to the client (no VITE_ prefix). Local dev value from
# `supabase status`.
# SUPABASE_SERVICE_ROLE_KEY=

# ── Twitter / X (developer.twitter.com → Projects & Apps) ─────────────────────
# Enable OAuth 2.0 in the app's "User authentication settings".
# Scopes needed: tweet.read, users.read
# TWITTER_CLIENT_ID=your-client-id
# TWITTER_CLIENT_SECRET=your-client-secret

# ── Facebook (developers.facebook.com → My Apps → Facebook Login) ─────────────
# Scopes needed: email, public_profile
# FACEBOOK_CLIENT_ID=your-app-id
# FACEBOOK_CLIENT_SECRET=your-app-secret

# ── LinkedIn (linkedin.com/developers → My Apps → Auth) ───────────────────────
# Uses LinkedIn OIDC (OpenID Connect). App must have "Sign In with LinkedIn" enabled.
# Scopes needed: openid, profile, email
# LINKEDIN_CLIENT_ID=your-client-id
# LINKEDIN_CLIENT_SECRET=your-client-secret

# ── Discord (discord.com/developers/applications) ──────────────────────────────
# Scopes needed: identify, email
# DISCORD_CLIENT_ID=your-client-id
# DISCORD_CLIENT_SECRET=your-client-secret

# ── Apple (developer.apple.com → Certificates, Identifiers & Profiles) ─────────
# Requires a Services ID, Team ID, Key ID, and .p8 private key.
# APPLE_CLIENT_ID is your Services ID (e.g. com.yourapp.auth).
# APPLE_SECRET is a generated JWT (sign it with your .p8 key — not the raw key).
# APPLE_CLIENT_ID=com.yourapp.auth
# APPLE_SECRET=eyJ...generated-jwt...

# ── Microsoft / Azure (portal.azure.com → Azure Active Directory → App registrations) ──
# Scopes needed: openid, email, profile
# MICROSOFT_TENANT_URL is https://login.microsoftonline.com/<tenant-id>/v2.0
# Use "common" as tenant-id for multi-tenant apps.
# MICROSOFT_CLIENT_ID=your-client-id
# MICROSOFT_CLIENT_SECRET=your-client-secret
# MICROSOFT_TENANT_URL=https://login.microsoftonline.com/common/v2.0
