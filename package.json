{
  "name": "spd-app-foundation-template",
  "private": true,
  "version": "0.1.0",
  "description": "ScreenPlayDesign master boilerplate — Vite 8 + React 19 + Tailwind 4 PWA with Supabase client hooks",
  "type": "module",
  "scripts": {
    "predev": "bun run scripts/require-container.ts",
    "dev": "vite",
    "prepreview": "bun run scripts/require-container.ts",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "playwright test",
    "test:smoke": "playwright test --grep @smoke",
    "seed:actors": "bun run scripts/seed-actors.ts",
    "screenplay:check": "spd screenplay check"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.46.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.0",
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "^26.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.0.0",
    "tailwindcss": "^4.3.0",
    "typescript": "^5.6.0",
    "vite": "^8.0.0"
  }
}
